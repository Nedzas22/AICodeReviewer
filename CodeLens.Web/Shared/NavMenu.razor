@inject NavigationManager Navigation
@inject IAuthService AuthService

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/dashboard">
            <i class="bi bi-code-slash me-2"></i>CodeLens
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/dashboard" Match="NavLinkMatch.Prefix">
                                <i class="bi bi-grid-fill me-1"></i>Dashboard
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/submit" Match="NavLinkMatch.All">
                                <i class="bi bi-plus-circle me-1"></i>New Review
                            </NavLink>
                        </li>
                    </Authorized>
                </AuthorizeView>
            </ul>
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-2">
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <span class="nav-link text-white-50 small">
                                <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <button class="btn btn-outline-light btn-sm" @onclick="LogoutAsync">
                                <i class="bi bi-box-arrow-right me-1"></i>Sign Out
                            </button>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/login">Sign In</NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="btn btn-outline-light btn-sm px-3" href="/register">Register</NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

@code {
    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
