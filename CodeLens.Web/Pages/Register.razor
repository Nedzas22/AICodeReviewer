@page "/register"
@layout AuthLayout
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Create Account — CodeLens</PageTitle>

<div class="auth-container" style="max-width:460px">
    <div class="card shadow border-0">
        <div class="card-body p-4 p-sm-5">

            <div class="text-center mb-4">
                <i class="bi bi-code-slash display-4 text-primary"></i>
                <h1 class="h4 mt-2 fw-bold">Create your account</h1>
                <p class="text-muted small mb-0">Start reviewing code with AI</p>
            </div>

            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-circle me-1"></i>@_errorMessage
                </div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="register">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label fw-medium">Display name</label>
                    <InputText @bind-Value="_model.DisplayName" class="form-control"
                               placeholder="Ada Lovelace" autocomplete="name" />
                    <ValidationMessage For="() => _model.DisplayName" class="invalid-feedback d-block small" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-medium">Email address</label>
                    <InputText @bind-Value="_model.Email" class="form-control"
                               placeholder="you@example.com" type="email" autocomplete="email" />
                    <ValidationMessage For="() => _model.Email" class="invalid-feedback d-block small" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-medium">Password</label>
                    <InputText @bind-Value="_model.Password" class="form-control"
                               type="password" autocomplete="new-password" />
                    <ValidationMessage For="() => _model.Password" class="invalid-feedback d-block small" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium">Confirm password</label>
                    <InputText @bind-Value="_model.ConfirmPassword" class="form-control"
                               type="password" autocomplete="new-password" />
                    <ValidationMessage For="() => _model.ConfirmPassword" class="invalid-feedback d-block small" />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2" disabled="@_loading">
                    @if (_loading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    Create Account
                </button>
            </EditForm>

            <hr class="my-4" />
            <p class="text-center mb-0 text-muted small">
                Already have an account?
                <a href="/login" class="fw-medium text-decoration-none">Sign in</a>
            </p>
        </div>
    </div>
</div>

@code {
    private readonly RegisterRequest _model = new();
    private string? _errorMessage;
    private bool _loading;

    private async Task HandleSubmitAsync()
    {
        _loading = true;
        _errorMessage = null;

        var result = await AuthService.RegisterAsync(_model);

        if (result.IsSuccess)
        {
            Navigation.NavigateTo("/dashboard");
        }
        else
        {
            _errorMessage = result.ErrorMessage;
            _loading = false;
        }
    }
}
