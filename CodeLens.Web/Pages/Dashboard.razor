@page "/"
@page "/dashboard"
@attribute [Authorize]
@inject IReviewService ReviewService
@inject NavigationManager Navigation

<PageTitle>Dashboard — CodeLens</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-bold mb-0">Review Dashboard</h1>
        <p class="text-muted small mb-0">Your AI code review history</p>
    </div>
    <a href="/submit" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>New Review
    </a>
</div>

@if (_loading)
{
    <LoadingSpinner Message="Loading reviews..." />
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle me-2"></i>@_errorMessage
    </div>
}
else if (_result is null || _result.TotalCount == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <h4 class="mt-3 fw-semibold">No reviews yet</h4>
        <p class="text-muted">Submit your first code snippet to get AI feedback.</p>
        <a href="/submit" class="btn btn-primary mt-2">
            <i class="bi bi-plus-circle me-2"></i>Submit code for review
        </a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <small class="text-muted">
            Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _result.TotalCount))
            of @_result.TotalCount review@(_result.TotalCount == 1 ? "" : "s")
        </small>
    </div>

    <div class="row g-3">
        @foreach (var review in _result.Items)
        {
            <div class="col-12">
                <div class="card shadow-sm border-0 review-card"
                     style="cursor:pointer"
                     @onclick="() => Navigation.NavigateTo($"/reviews/{review.Id}")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                            <div class="flex-grow-1 min-w-0">
                                <h6 class="mb-1 fw-semibold text-truncate">@review.Title</h6>
                                <div class="d-flex gap-2 flex-wrap align-items-center">
                                    <span class="badge bg-secondary">@review.Language.ToDisplayName()</span>
                                    <small class="text-muted">
                                        @review.IssueCount issue@(review.IssueCount == 1 ? "" : "s")
                                    </small>
                                    <small class="text-muted">
                                        @review.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
                                    </small>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                @if (review.OverallScore.HasValue)
                                {
                                    <ScoreDisplay Score="review.OverallScore.Value" />
                                }
                                <StatusBadge Status="review.Status" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(review.Summary))
                        {
                            <p class="mb-0 mt-2 text-muted small summary-truncate">@review.Summary</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (_result.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Review history pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(_result.HasPreviousPage ? "" : "disabled")">
                    <button class="page-link" @onclick="() => LoadPageAsync(_page - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </li>
                @for (var i = 1; i <= _result.TotalPages; i++)
                {
                    var pageNum = i;
                    <li class="page-item @(pageNum == _page ? "active" : "")">
                        <button class="page-link" @onclick="() => LoadPageAsync(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(_result.HasNextPage ? "" : "disabled")">
                    <button class="page-link" @onclick="() => LoadPageAsync(_page + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </li>
            </ul>
        </nav>
    }
}

@code {
    private PagedResult<CodeReviewDto>? _result;
    private bool _loading = true;
    private string? _errorMessage;
    private int _page = 1;
    private const int PageSize = 10;

    protected override async Task OnInitializedAsync() =>
        await LoadPageAsync(1);

    private async Task LoadPageAsync(int page)
    {
        _loading = true;
        _errorMessage = null;
        _page = page;

        var result = await ReviewService.GetHistoryAsync(page, PageSize);

        if (result.IsSuccess)
            _result = result.Data;
        else
            _errorMessage = result.ErrorMessage;

        _loading = false;
    }
}
